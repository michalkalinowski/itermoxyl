#!/usr/bin/env python3

import argparse
import re
import signal
import subprocess
import sys
from math import ceil, sqrt
from os.path import expanduser, normpath, join

CONFIG_PATH = expanduser("~/.ssh/")

parser = argparse.ArgumentParser(
    description=(
        "Tool to open multiple SSH connections in iTerm2. Use `--find` to search ~/.ssh/known_hosts and ~/.ssh/config by regex, or `--list` to specify hosts directly."
    )
)
mode_group = parser.add_mutually_exclusive_group(required=False)
mode_group.add_argument(
    "-f",
    "--find",
    dest="mode",
    action="store_const",
    const="find",
    help="Search hosts from known_hosts and ssh config using regex patterns",
)
mode_group.add_argument(
    "-l",
    "--list",
    dest="mode",
    action="store_const",
    const="list",
    help="Use the following hosts or IPs directly",
)
parser.add_argument(
    "-r",
    "--run",
    dest="should_actually_run",
    action="store_true",
    default=False,
    help="Skip confirmation and immediately open panes",
)
parser.add_argument(
    "-d",
    "--debug",
    action="store_true",
    default=False,
    help="Dump the generated AppleScript and exit",
)
parser.add_argument(
    "-v", "--version", action="store_true", default=False, help="Print version and exit"
)
layout_group = parser.add_mutually_exclusive_group()
layout_group.add_argument(
    "-C",
    "--columns",
    dest="columns",
    type=int,
    default=None,
    metavar="N",
    help="Number of columns (rows grow as needed); default is adaptive based on host count",
)
layout_group.add_argument(
    "-R",
    "--rows",
    dest="rows",
    type=int,
    default=None,
    metavar="N",
    help="Number of rows (columns grow as needed)",
)
parser.add_argument(
    "hosts",
    nargs="*",
    help="Regex patterns (in find mode) or explicit hosts/IPs (in list mode)",
)
arguments = parser.parse_args()


def signal_handler(sig, frame):
    sys.exit(0)


if arguments.version:
    print("2.0.0")
    sys.exit(0)

if not arguments.mode:
    parser.error("One of --find/-f or --list/-l is required (unless using --version)")


def load_known_hosts(known_hosts_file="known_hosts"):
    path = normpath(join(CONFIG_PATH, known_hosts_file))
    hosts = set()
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                host_field = line.split()[0]
                for h in host_field.split(","):
                    if h.startswith("|"):
                        continue
                    if h.startswith("[") and "]" in h:
                        h = h[1 : h.index("]")]
                    hosts.add(h)
    except FileNotFoundError:
        pass
    return hosts


def load_ssh_config(config_file="config"):
    path = normpath(join(CONFIG_PATH, config_file))
    hosts = set()
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                parts = line.split()
                if parts[0].lower() == "host" and len(parts) > 1:
                    for h in parts[1:]:
                        if any(c in h for c in ["*", "?", "[", "]"]):
                            continue
                        hosts.add(h)
    except FileNotFoundError:
        pass
    return hosts


def load_hosts():
    known = load_known_hosts()
    config = load_ssh_config()
    combined = known.union(config)
    if not combined:
        print(f"No hosts found in {CONFIG_PATH}known_hosts or {CONFIG_PATH}config")
        sys.exit(1)
    return combined


def check_if_iterm_version_is_supported():
    process = subprocess.Popen(
        ["osascript", "-"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        universal_newlines=True,
    )
    version_script = 'set iterm_version to (get version of application "iTerm")'
    version = process.communicate(version_script)[0].strip()
    match = re.search(r"^(\d+)\.(\d+)", version)
    if match:
        major, minor = int(match.group(1)), int(match.group(2))
        return (major > 2) or (major == 2 and minor > 9)
    return False


def prompt_for_confirmation(count):
    choice = input(f"\nOpen {count} panes? [y/N] ").strip().lower()
    return choice == "y"


def create_pane(parent, child, orientation):
    return f"""
        tell pane_{parent}
            set pane_{child} to (split {orientation}ly with same profile)
        end tell
        """


def init_pane(num, host):
    return f"""
        tell pane_{num}
            write text "ssh {host}"
            set name to "{host}"
        end tell
        """


def _default_columns(n):
    columns = round(sqrt(n))
    columns = max(1, columns)
    last_row_panes = n % columns or columns
    if last_row_panes < columns / 2:
        columns -= 1
    return max(1, columns)


def build_applescript(hosts, columns=None):
    n = len(hosts)
    num_cols = min(columns if columns is not None else _default_columns(n), n)
    num_rows = int(ceil(n / num_cols))
    pane_creation = ""

    for row in range(1, num_rows):
        parent = 1 + (row - 1) * num_cols
        child = parent + num_cols
        pane_creation += create_pane(parent, child, "horizontal")

    for row in range(num_rows):
        row_start = 1 + row * num_cols
        panes_in_row = min(num_cols, n - row * num_cols)
        for col in range(1, panes_in_row):
            parent = row_start + col - 1
            child = parent + 1
            pane_creation += create_pane(parent, child, "vertical")

    init_script = "".join(init_pane(i + 1, h) for i, h in enumerate(hosts))

    return f"""
        tell application "iTerm"
            activate
            tell current window
                set new_tab to (create tab with default profile)
                tell new_tab
                    set pane_1 to current session
                    {pane_creation}
                    {init_script}
                end tell
            end tell
        end tell
        """


def run_applescript(script):
    process = subprocess.Popen(
        ["osascript", "-"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        universal_newlines=True,
    )
    stdout, stderr = process.communicate(script)
    if process.returncode != 0:
        print(f"AppleScript error:\n{stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    if stdout:
        print(stdout)


_SAFE_HOST_RE = re.compile(r"^[A-Za-z0-9._:\-\[\]]+$")


def validate_hosts(hosts):
    for h in hosts:
        if not _SAFE_HOST_RE.match(h):
            print(f"Invalid hostname (unsafe characters): {h}", file=sys.stderr)
            sys.exit(1)


def split_host_by_prefix_and_suffix(host):
    m = re.match(r"(\D+)(\d+)$", host)
    if m:
        return m.group(1), int(m.group(2))
    return host, 0


def sort_hosts(hosts):
    return sorted(hosts, key=lambda h: split_host_by_prefix_and_suffix(h))


def main():
    if not check_if_iterm_version_is_supported():
        print("iTerm2 version not supported or not installed")
        sys.exit(1)

    if arguments.mode == "list":
        if not arguments.hosts:
            print("No hosts provided for --list mode.")
            sys.exit(1)
        selected = arguments.hosts
    else:  # find mode
        if not arguments.hosts:
            parser.error("At least one regex pattern is required for --find mode.")
        loose = ".*?".join(f"(?:{p})" for p in arguments.hosts)
        pat = re.compile(loose, re.IGNORECASE)
        all_hosts = load_hosts()
        selected = [h for h in all_hosts if pat.search(h)]
        if not selected:
            print("No hosts match the given pattern.")
            sys.exit(0)
        selected = sort_hosts(selected)

    print("Will open the following hosts:\n")
    for h in selected:
        print(f"- {h}")

    validate_hosts(selected)

    if arguments.columns is not None and arguments.columns < 1:
        parser.error("--columns must be >= 1")
    if arguments.rows is not None and arguments.rows < 1:
        parser.error("--rows must be >= 1")

    if arguments.rows is not None:
        columns = int(ceil(len(selected) / arguments.rows))
    elif arguments.columns is not None:
        columns = arguments.columns
    else:
        columns = None  # build_applescript will compute the default

    script = build_applescript(selected, columns=columns)
    if arguments.debug:
        print(script)
        return

    # Confirmation / run logic
    if arguments.should_actually_run:
        run_applescript(script)
    else:
        if prompt_for_confirmation(len(selected)):
            run_applescript(script)
        else:
            print("Aborted.")


if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal_handler)
    main()
